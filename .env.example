# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — the app reads these. Production must have them set.
# ─────────────────────────────────────────────────────────────────────────────

# Redis (ParvoMap Upstash database, separate from Scoopie).
# In production these are injected by the Vercel↔Upstash integration as
# KV_REST_API_URL / KV_REST_API_TOKEN — the code falls back to those. Set the
# UPSTASH_* pair for local dev. (Leave UPSTASH_* unset/placeholder in prod.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (ParvoMap account that owns the verified parvomaps.us domain). All email.
RESEND_API_KEY=

# Where Utah lead alerts are sent (currently support@scoopie.us).
SCOOPIE_ALERT_EMAIL=

# Cron auth. If set, Vercel Cron automatically sends it as a Bearer token to
# /api/cron/*. Generate with: openssl rand -hex 32
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# FUTURE — referenced in plans but NOT yet read by any code. Safe to leave blank.
# (Stripe routes and the subscribe route are stubs; map center is hardcoded.)
# ─────────────────────────────────────────────────────────────────────────────

# Stripe — /pro hosted Checkout + webhook are LIVE (automatic sales tax on).
# /pro reads the Price ids below; missing/placeholder ids make that plan's
# button return a friendly "not available yet" instead of erroring.
# STRIPE_SECRET_KEY=                     # sk_live_… — the server secret key
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=    # pk_live_… — safe to expose client-side
# STRIPE_WEBHOOK_SECRET=                 # whsec_… — from the /api/stripe/webhook endpoint
# STRIPE_GUARDIAN_MONTHLY_PRICE_ID=      # price_… consumer SaaS, tax code txcd_10103002
# STRIPE_GUARDIAN_ANNUAL_PRICE_ID=       # price_…
# STRIPE_PRO_CLINIC_PRICE_ID=            # price_… business SaaS, tax code txcd_10103001
# STRIPE_PRO_ENTERPRISE_PRICE_ID=        # price_… (reserved; no /pro tier yet)

# Scoopie Redis cross-writes (Utah lead sync) — planned, not implemented.
# SCOOPIE_REDIS_REST_URL=
# SCOOPIE_REDIS_REST_TOKEN=

# Slack notifications — planned, not implemented.
# SLACK_WEBHOOK_URL=

# OpenAI — image moderation for lost-dog photo uploads. When set, every upload
# is screened (nudity/gore/violence) via the free omni-moderation endpoint and
# rejected before it reaches Blob storage. If unset, uploads skip moderation
# (fail open) and rely on the 🚩 flag → dashboard backstop.
# OPENAI_API_KEY=

# Photo uploads for lost-dog reports (Vercel Blob). Auto-injected by Vercel when
# a Blob store is connected to the project; set manually for local testing.
# Without it, the lost-dog form still works — photo upload is just disabled.
# BLOB_READ_WRITE_TOKEN=

# Moderation dashboard (/admin?key=...). Set a long random string; the same key
# guards the remove/dismiss admin actions. Without it, /admin is locked.
# ADMIN_KEY=

# Off-site backups → Cloudflare R2 (S3-compatible). The daily /api/cron/backup
# job is DORMANT until all four are set, then writes a dated Redis snapshot +
# repo tarball to the bucket. Use a LEAST-PRIVILEGE R2 token (Object Read & Write,
# no delete) and enable bucket Versioning + Object Lock so backups can't be wiped.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=parvomaps-backups
