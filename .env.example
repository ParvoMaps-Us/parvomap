# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — the app reads these. Production must have them set.
# ─────────────────────────────────────────────────────────────────────────────

# Redis (ParvoMap Upstash database, separate from Scoopie).
# In production these are injected by the Vercel↔Upstash integration as
# KV_REST_API_URL / KV_REST_API_TOKEN — the code falls back to those. Set the
# UPSTASH_* pair for local dev. (Leave UPSTASH_* unset/placeholder in prod.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (ParvoMap account that owns the verified parvomaps.us domain). All email.
RESEND_API_KEY=

# Where Utah lead alerts are sent (currently support@scoopie.us).
SCOOPIE_ALERT_EMAIL=

# Cron auth. If set, Vercel Cron automatically sends it as a Bearer token to
# /api/cron/*. Generate with: openssl rand -hex 32
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# FUTURE — referenced in plans but NOT yet read by any code. Safe to leave blank.
# (Stripe routes and the subscribe route are stubs; map center is hardcoded.)
# ─────────────────────────────────────────────────────────────────────────────

# Stripe — payments/subscriptions not wired up yet.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_GUARDIAN_MONTHLY_PRICE_ID=
# STRIPE_GUARDIAN_ANNUAL_PRICE_ID=
# STRIPE_PRO_CLINIC_PRICE_ID=
# STRIPE_PRO_ENTERPRISE_PRICE_ID=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Scoopie Redis cross-writes (Utah lead sync) — planned, not implemented.
# SCOOPIE_REDIS_REST_URL=
# SCOOPIE_REDIS_REST_TOKEN=

# Slack notifications — planned, not implemented.
# SLACK_WEBHOOK_URL=

# Photo uploads for lost-dog reports (Vercel Blob). Auto-injected by Vercel when
# a Blob store is connected to the project; set manually for local testing.
# Without it, the lost-dog form still works — photo upload is just disabled.
# BLOB_READ_WRITE_TOKEN=
